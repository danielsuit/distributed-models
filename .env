# Distributed Models environment configuration
# Copy this file to your shell environment or load it with `dotenvy`.

# Where the Rust backend listens for the VS Code extension.
DM_HOST=127.0.0.1
DM_PORT=7878

# Redis connection used as the agent message bus.
REDIS_URL=redis://127.0.0.1:6379/

# Ollama HTTP endpoint (the install.sh script will start this for you).
OLLAMA_ENDPOINT=http://127.0.0.1:11434

# Per-agent model assignments. Override any of these to swap models.
# Recommended defaults (run `ollama pull` for each):
#   DM_MODEL_ORCHESTRATOR=qwen2.5-coder:7b
#   DM_MODEL_FILE_STRUCTURE=llama3.2:3b
#   DM_MODEL_CODE_WRITER=qwen2.5-coder:14b
#   DM_MODEL_ERROR=qwen2.5-coder:7b
#   DM_MODEL_REVIEW=qwen2.5-coder:7b
DM_MODEL_ORCHESTRATOR=qwen2.5-coder:7b
DM_MODEL_FILE_STRUCTURE=qwen2.5-coder:7b
DM_MODEL_CODE_WRITER=deepseek-coder-v2:16b
DM_MODEL_ERROR=qwen2.5-coder:7b
DM_MODEL_REVIEW=qwen2.5-coder:7b

# Logging level for the Rust backend.
RUST_LOG=info,distributed_models=debug
